---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { dateToSlug } from '../utils/slug';
import { formatItalianDate } from '../utils/date';

// Archivio ordinato dal più recente.
const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

// Anteprima social della home: l'immagine del post più recente (se esiste).
const shareImage = posts[0]?.data.image;
---

<Base
  description="Estate, il tempo lento — archivio di testi e immagini."
  image={shareImage}
>
  <header class="head">
    <h1>Estate, il tempo lento</h1>
    <p class="intro">
      Un archivio personale: testi originali affiancati a immagini generate con
      l'intelligenza artificiale, un giorno alla volta. Pubblicati anche su
      Threads, <a href="https://www.threads.net/@fabpicca">@fabpicca</a>.
    </p>
  </header>

  <ul class="grid">
    {
      posts.map((post) => {
        const slug = dateToSlug(post.data.date);
        return (
          <li>
            <a class="card" href={`/estate-il-tempo-lento/${slug}`}>
              <img src={post.data.image} alt="" loading="lazy" />
              <span class="meta">
                <time class="date" datetime={post.data.date.toISOString()}>
                  {formatItalianDate(post.data.date)}
                </time>
                {post.data.excerpt && <span class="excerpt">{post.data.excerpt}</span>}
              </span>
            </a>
          </li>
        );
      })
    }
  </ul>
</Base>

<style>
  .head {
    max-width: 1240px;
    margin: 0 auto;
    padding: clamp(4rem, 12vh, 8rem) 1.5rem 2rem;
  }

  h1 {
    margin: 0;
    font-family: var(--display);
    font-weight: 800;
    font-size: clamp(2.8rem, 9vw, 6rem);
    line-height: 1.02;
    letter-spacing: -0.015em;
  }

  .intro {
    margin: 1.5rem 0 0;
    max-width: 640px;
    color: var(--muted);
    font-size: 1.15rem;
    font-style: italic;
    line-height: 1.7;
  }

  .intro a {
    color: var(--ink);
    text-underline-offset: 3px;
    text-decoration-color: var(--accent);
  }

  .grid {
    list-style: none;
    margin: 0 auto;
    padding: 2rem 1.5rem 6rem;
    max-width: 1240px;
    columns: 320px;
    column-gap: 0.6rem;
  }

  .grid li {
    break-inside: avoid;
    margin-bottom: 0.6rem;
  }

  .card {
    position: relative;
    display: block;
    overflow: hidden;
    text-decoration: none;
    background: #17151a;
  }

  /* Le immagini generate hanno tutte lo stesso rapporto: per ottenere lo
     sfalsamento a masonry variamo l'altezza delle tessere ritagliandole con
     rapporti diversi in ciclo (il dettaglio mostra sempre l'immagine intera). */
  .card {
    aspect-ratio: 3 / 4;
  }

  .grid li:nth-child(4n + 1) .card {
    aspect-ratio: 2 / 3;
  }

  .grid li:nth-child(4n + 2) .card {
    aspect-ratio: 1 / 1;
  }

  .grid li:nth-child(4n + 3) .card {
    aspect-ratio: 4 / 5;
  }

  .card img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.72) saturate(0.95);
    transform: scale(1.02);
    transition:
      transform 1.1s cubic-bezier(0.16, 1, 0.3, 1),
      filter 0.8s ease;
  }

  .card:hover img,
  .card:focus-visible img {
    filter: brightness(0.95) saturate(1);
    transform: scale(1.08);
  }

  .meta {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.5rem;
    padding: 1.5rem;
    color: #fff;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.85),
      rgba(0, 0, 0, 0) 65%
    );
  }

  .date {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .excerpt {
    font-family: var(--display);
    font-size: 1.5rem;
    line-height: 1.25;
    transform: translateY(0.4rem);
    opacity: 0.9;
    transition:
      transform 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.6s ease;
  }

  .card:hover .excerpt,
  .card:focus-visible .excerpt {
    transform: translateY(0);
    opacity: 1;
  }
</style>
