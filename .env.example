# Variabili d'ambiente per l'endpoint di pubblicazione (api/publish.js).
# Su Vercel: Project Settings → Environment Variables. NON committare i valori reali.

# Password condivisa del form /pubblica (scegline una lunga).
PUBLISH_SECRET=

# Fine-grained GitHub PAT, scope: SOLO il repo estate-il-tempo-lento,
# permesso "Contents: Read and write".
GITHUB_TOKEN=

# owner/repo di destinazione dei commit.
GITHUB_REPO=fabpicca/estate-il-tempo-lento

# Branch su cui committare (opzionale, default "main").
GITHUB_BRANCH=main
